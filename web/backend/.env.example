# Copy to .env and fill in values.
# This file is safe to commit. .env is gitignored.

# ── Fireworks (LLM coordinator) ────────────────────────────────────────────
# Get from: https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# ── Modal (compute infra) ──────────────────────────────────────────────────
# Populated automatically by `python3 -m modal setup`.
# Only needed if you want non-interactive auth (CI/CD).
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ── Backend misc ───────────────────────────────────────────────────────────
# Restrict CORS in production to your frontend domain.
FRONTEND_ORIGIN=http://localhost:3000
